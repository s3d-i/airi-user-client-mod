{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@airi/airi-ws-bridge": ["packages/airi-ws-bridge/src/index.ts"],
      "@airi/hub-ingress-ws": ["packages/hub-ingress-ws/src/index.ts"],
      "@airi/hub-runtime": ["packages/hub-runtime/src/index.ts"]
    }
  }
}
